        "\n",
        "def to_slug(x):\n",
        "    # Convert to lowercase\n",
        "    x = x.lower()\n",
        "    # Replace non-alphanumeric characters (except spaces and hyphens) with space\n",
        "    x = re.sub(r\"[^a-z0-9\\s-]\", \" \", x)\n",
        "    # Replace spaces and multiple hyphens with a single hyphen\n",
        "    x = re.sub(r\"[\\s]+\", \"-\", x)\n",
        "    return x.strip(\"-\")  # Remove leading/trailing hyphens\n",
        "\n",
        "def parse_and_validate_json(json_string):\n",
        "    # Remove markdown code block delimiters if present\n",
        "    json_string = json_string.strip()\n",
        "    if json_string.startswith(\"```json\"):\n",
        "        json_string = json_string[7:]  # Remove \"```json\\n\"\n",
        "    if json_string.endswith(\"```\"):\n",
        "        json_string = json_string[:-3].strip() # remove \"```\"\n",
        "    try:\n",
        "        data = json.loads(json_string)\n",
        "        required_keys = [\"product_description\", \"meta_title\", \"meta_description\", \"longtail_keyword\", \"product_tags\"]\n",
        "        if all(key in data for key in required_keys):\n",
        "            return data\n",
        "        else:\n",
        "            print(f\"JSON is missing required keys. Found keys: {data.keys()}\")\n",
        "            return None\n",
        "    except json.JSONDecodeError as e:\n",
        "        print(f\"JSON decoding error: {e}\")\n",
        "        return None\n",
        "\n",
        "def generate_gpt_response(title, description, max_retries=5, base_wait_time=1):\n",
        "    for attempt in range(1, max_retries + 1):\n",
        "        try:\n",
        "            prompt = f\"\"\"\n",
        "            Generate a JSON object for my woocommerce web store product listing using the suppliers product title ({title}) and description ({description}), along with live SEO-optimized internet data.\n",
        "\n",
        "            Output format:\n",
        "            {{\n",
        "              \"product_description\": \"SEO-optimized long description in html format (with either or all <h2>, <h3>, <h4>, <p>, <ul>, <li>)\",\n",
        "              \"meta_title\": \"SEO-optimized meta title with length not more than 60 characters incorporating all important words from the provided title\",\n",
        "              \"meta_description\": \"Compelling, click-enticing meta description (max 100 characters)\",\n",
        "              \"longtail_keyword\": \"SEO long-tail keyword\",\n",
        "              \"product_tags\": \"5 to 10 highly relevant product tags (comma-separated) highlighting key features and benefits\"\n",
        "            }}\n",
        "\n",
        "            Remember, don't use any words related to my competitor: Luxe Decor, including sku, item_number, or texts related to a link, anywhere in response, Also don't use custom input text, buttons, etc.\n",
        "            \"\"\"\n",
        "\n",
        "            response = model.generate_content(prompt)\n",
        "            json_data = parse_and_validate_json(response.text.strip())\n",
        "\n",
        "            if json_data:\n",
        "                return json_data\n",
        "            else:\n",
        "                print(f\"Attempt {attempt} failed: Invalid JSON.\")\n",
        "                print(f\"Response text: {response.text.strip()}\")\n",
        "\n",
        "        except Exception as e:\n",
        "            print(f\"Attempt {attempt} failed: {e}\")\n",
        "\n",
        "        if attempt < max_retries:\n",
        "            wait_time = base_wait_time * (2 ** (attempt - 1))  # Exponential backoff\n",
        "            print(f\"Retrying in {wait_time} seconds...\")\n",
        "            time.sleep(wait_time)\n",
        "        else:\n",
        "            print(\"Max retries reached. Exiting.\")\n",
        "            return None\n",
        "\n",
        "def download_image(image_url, filename):\n",
        "    try:\n",
        "        # Fetch the image from the URL\n",
        "        response = requests.get(image_url, stream=True)\n",
        "        response.raise_for_status()  # Raise an exception for error HTTP status codes\n",
        "\n",
        "        # Open the image from the response content\n",
        "        img = Image.open(BytesIO(response.content))\n",
        "\n",
        "        # Handle images with transparency\n",
        "        if img.mode == \"P\" or img.mode == \"RGBA\":\n",
        "            img = img.convert(\"RGBA\")\n",
        "            # Create a white background image\n",
        "            white_background = Image.new(\"RGBA\", img.size, (255, 255, 255, 255))\n",
        "            # Blend the original image with the white background\n",
        "            img = Image.alpha_composite(white_background, img)\n",
        "\n",
        "        # Convert to RGB (for consistent background)\n",
        "        if img.mode != \"RGB\":\n",
        "            img = img.convert(\"RGB\")\n",
        "\n",
        "        # Get the dimensions of the image\n",
        "        width, height = img.size\n",
        "\n",
        "        # Create a new white background image (square dimensions)\n",
        "        new_size = max(width, height)\n",
        "        background = Image.new(\"RGB\", (new_size, new_size), (255, 255, 255))\n",
        "\n",
        "        # Paste the original image onto the white background (centered)\n",
        "        offset = ((new_size - width) // 2, (new_size - height) // 2)\n",
        "        background.paste(img, offset)\n",
        "\n",
        "        # Save the processed image\n",
        "        background.save(filename)\n",
        "\n",
        "        return filename\n",
        "    except requests.exceptions.RequestException as e:\n",
        "        print(f\"Failed to download image: {e}\")\n",
        "        return None\n",
        "    except Exception as e:\n",
        "        print(f\"Error processing image: {e}\")\n",
        "        return None\n",
        "\n",
        "def upload_image_from_local(filepath):\n",
        "    url = 'https://freeimage.host/api/1/upload'\n",
        "    files = {\n",
        "        'source': open(filepath, 'rb')\n",
        "    }\n",
        "    data = {\n",
        "        'key': ImageHost_API_KEY,\n",
