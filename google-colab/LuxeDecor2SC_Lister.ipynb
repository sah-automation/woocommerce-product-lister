        "    if response.status_code == 200:\n",
        "        result = response.json()\n",
        "        if result['status_code'] == 200:\n",
        "            image_url = result['image']['url']\n",
        "            return image_url\n",
        "        else:\n",
        "            print(\"Error:\", result['status_txt'])\n",
