        "        return False\n",
        "  except Exception as e:\n",
        "      print(f\"Exception during SKU check for {sku}: {e}\")\n",
        "      return False\n",
        "\n",
        "def image_exists(image_url):\n",
        "    try:\n",
        "        # Search for images in WooCommerce that match the provided URL\n",
        "        response = requests.get(f\"{base_url}media?search={image_url}\", auth=auth)\n",
        "        if response.status_code == 200:\n",
        "            images = response.json()\n",
        "            return any(img['source_url'] == image_url for img in images)\n",
        "        else:\n",
        "            print(f\"Error checking image existence: {response.text}\")\n",
        "            return False\n",
        "    except Exception as e:\n",
        "        print(f\"Exception while checking image existence: {e}\")\n",
        "        return False\n",
        "\n",
        "# Function to get image ID by image_URL\n",
        "def get_image_id(image_url):\n",
        "    try:\n",
        "        # Search for images in WooCommerce that match the provided URL\n",
        "        response = requests.get(f\"{base_url}media?search={image_url}\", auth=auth)\n",
        "        if response.status_code == 200:\n",
        "            data = response.json()\n",
        "            for item in data:\n",
        "                if item.get(\"source_url\") == image_url:\n",
        "                    return item.get(\"id\")\n",
        "        return None\n",
        "    except Exception as e:\n",
        "        print(f\"Exception while checking image existence: {e}\")\n",
        "        return False\n",
        "\n",
        "# Function to create a product (simple or variable parent)\n",
        "def create_product(data):\n",
        "    try:\n",
        "        url = f\"{base_url}products\"\n",
        "        response = requests.post(url, json=data, auth=auth)\n",
        "        response.raise_for_status()\n",
        "        return response.json()\n",
        "    except requests.exceptions.RequestException as e:\n",
        "        print(f\"Error creating product {data.get('name', 'Unknown')}: {e}\")\n",
        "        return {}\n",
        "\n",
        "# Function to create a variation for a variable product\n",
        "def create_variation(product_id, variation_data):\n",
        "    try:\n",
        "        url = f\"{base_url}products/{product_id}/variations\"\n",
        "        response = requests.post(url, json=variation_data, auth=auth)\n",
        "        response.raise_for_status()\n",
        "        return response.json()\n",
        "    except requests.exceptions.RequestException as e:\n",
        "        print(f\"Error creating variation for product ID {product_id}: {e}\")\n",
        "        return response.json()\n",
        "\n",
        "# Function to rename attribute key and value from old to new\n",
        "def rename_attributes(spec_key_list, spec_value_list):\n",
        "    new_spec_key_list = []\n",
        "    for spec_key in spec_key_list:\n",
        "        if spec_key in new_spec_keys:\n",
        "            index = new_spec_keys.index(spec_key)\n",
        "            spec_key = old_spec_keys[index]\n",
        "            new_spec_key_list.append(spec_key)\n",
        "        else:\n",
        "            new_spec_key_list.append(spec_key)\n",
        "\n",
        "    new_spec_value_list = []\n",
        "    for spec_value in spec_value_list:\n",
        "        if spec_value in new_spec_values:\n",
        "            index = new_spec_values.index(spec_value)\n",
        "            spec_value = old_spec_values[index]\n",
        "            new_spec_value_list.append(spec_value)\n",
        "        else:\n",
        "            new_spec_value_list.append(spec_value)\n",
        "\n",
        "    return new_spec_key_list, new_spec_value_list\n",
        "\n",
        "# Function to safely create an attribute if it doesn't exist\n",
        "def create_attribute(key):\n",
        "    url = f\"{base_url}products/attributes\"\n",
        "    new_attribute = {\n",
        "        \"name\": key,\n",
        "        \"type\": \"select\",\n",
        "        \"order_by\": \"menu_order\",\n",
        "        \"has_archives\": False\n",
        "    }\n",
        "    try:\n",
        "        response = requests.post(url, json=new_attribute, auth=auth)\n",
        "        if response.status_code == 201:\n",
        "            print(f\"Successfully created attribute '{key}'\")\n",
        "            return response.json().get('id')\n",
        "        else:\n",
        "            print(f\"Error creating attribute '{key}': {response.status_code}, {response.text}\")\n",
        "    except Exception as e:\n",
        "        print(f\"Exception while creating attribute '{key}': {e}\")\n",
        "    return None\n",
        "\n",
        "# Function to get all existing attributes\n",
        "def get_existing_attributes():\n",
        "    url = f\"{base_url}products/attributes\"\n",
        "    try:\n",
        "        response = requests.get(url, auth=auth)\n",
        "        if response.status_code == 200:\n",
        "            return response.json()\n",
        "        else:\n",
        "            print(f\"Error fetching existing attributes: {response.status_code}, {response.text}\")\n",
        "    except Exception as e:\n",
        "        print(f\"Exception while fetching existing attributes: {e}\")\n",
        "    return []\n",
        "\n",
        "# Function to get all terms for a specific attribute\n",
        "def get_existing_terms(attribute_id):\n",
        "    \"\"\"Fetches all existing terms for an attribute, handling pagination.\"\"\"\n",
        "    existing_terms = []\n",
        "    page = 1\n",
        "\n",
        "    while True:\n",
        "        try:\n",
        "            url = f\"{base_url}products/attributes/{attribute_id}/terms\"\n",
        "            response = requests.get(url, params={'page': page, 'per_page': 100}, auth=auth)\n",
        "\n",
        "            if response.status_code == 200:\n",
        "                terms = response.json()\n",
        "                if not terms:  # If no terms are returned, break the loop\n",
        "                    break\n",
        "                existing_terms.extend(terms)\n",
        "                page += 1\n",
        "            else:\n",
        "                print(f\"Failed to fetch terms for attribute {attribute_id}: {response.status_code}, {response.text}\")\n",
        "                break\n",
        "        except Exception as e:\n",
        "            print(f\"Exception while fetching terms for attribute {attribute_id}: {e}\")\n",
        "            break\n",
        "\n",
        "    return existing_terms\n",
        "\n",
        "# Function to create a term if it doesn't exist\n",
        "def create_term(attribute_id, term_name):\n",
        "    url = f\"{base_url}products/attributes/{attribute_id}/terms\"\n",
        "    new_term = {\"name\": term_name}\n",
        "    try:\n",
        "        response = requests.post(url, json=new_term, auth=auth)\n",
        "        if response.status_code == 201:\n",
        "            print(f\"Successfully created term '{term_name}' for attribute ID {attribute_id}\")\n",
        "            return response.json().get('id')\n",
        "        else:\n",
        "            print(f\"Error creating term '{term_name}' for attribute ID {attribute_id}: {response.status_code}, {response.text}\")\n",
        "    except Exception as e:\n",
        "        print(f\"Exception while creating term '{term_name}' for attribute ID {attribute_id}: {e}\")\n",
        "    return None\n",
        "\n",
        "# Main process to update product attributes\n",
        "def update_product_attributes(product_id, spec_key_list, spec_value_list, variants_attribute):\n",
        "    existing_attributes = get_existing_attributes()\n",
        "    attributes = variants_attribute  # Existing attributes to keep, but each iteration will create its own attribute set\n",
        "\n",
        "    for key, value in zip(spec_key_list, spec_value_list):\n",
        "        if key == \"Type\":\n",
        "            key = \"Product Type\"\n",
        "\n",
        "        attribute_id = None\n",
        "        for attribute in existing_attributes:\n",
        "            if attribute['name'].strip().lower() == key.strip().lower():\n",
        "                attribute_id = attribute['id']\n",
        "                break\n",
        "\n",
        "        if not attribute_id:\n",
        "            attribute_id = create_attribute(key)\n",
        "            if attribute_id:\n",
        "                existing_attributes = get_existing_attributes()  # Refresh attribute list\n",
        "\n",
        "        if attribute_id:\n",
        "            existing_terms = get_existing_terms(attribute_id)\n",
        "\n",
        "            # 1️⃣ Normalize the text to remove odd Unicode characters\n",
        "            value = unicodedata.normalize('NFKD', value)  # Normalize Unicode (removes non-printable marks)\n",
        "\n",
        "            # 2️⃣ Remove control characters and non-printable characters\n",
        "            value = re.sub(r'[\\x00-\\x1F\\x7F\\u200B-\\u200F\\u202C\\uFEFF]', '', value)  # Remove control chars\n",
        "\n",
        "            # 4️⃣ Split by any of these delimiters: 2+ spaces, question mark, comma, or pipe\n",
        "            value_options = re.split(r'\\s{2,}|,', value)  # Split by 2 or more spaces, comma\n",
        "\n",
        "            # 5️⃣ Clean up individual values (remove whitespace and filter out empty strings)\n",
        "            value_options = [option.strip() for option in value_options if option.strip()]\n",
        "\n",
        "            #value_options = value.split(\", \")\n",
        "\n",
        "            option_names = []  # Reset option names for the current attribute only\n",
        "\n",
        "            for option in value_options:\n",
        "                option_cleaned = option.strip()  # Remove any leading/trailing whitespace\n",
        "                if not option_cleaned:  # Skip if the option is empty\n",
        "                    continue\n",
        "                term_id = None\n",
        "                for term in existing_terms:\n",
        "                    term_name_cleaned = unicodedata.normalize('NFKD', term['name']).strip()\n",
        "                    option_cleaned = unicodedata.normalize('NFKD', option_cleaned).strip()\n",
        "\n",
        "                    # Decode HTML entities\n",
        "                    term_name_cleaned = html.unescape(term_name_cleaned)\n",
        "                    option_cleaned = html.unescape(option_cleaned)\n",
        "\n",
