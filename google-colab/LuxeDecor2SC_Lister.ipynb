        "            thwvsf_swatches = [ { \"name\": variation_swatch_keys, \"type\": \"image\", \"variation\": True, \"terms\": { val: {\"name\": val, \"swatch image\": url} for val, url in zip(variation_swatch_values, variation_swatch_image_urls) } } ]\n",
        "\n",
        "            update_url = f\"{base_url}products/{parent_id}\"\n",
        "            swatch_data = {\n",
        "                \"meta_data\": image_swatch_meta,\n",
        "                \"thwvsf_swatches\": thwvsf_swatches\n",
        "            }\n",
        "            if variation_images[0].split(\",-,\")[0] == \"NA\":\n",
        "              print(\"Swatches not created: No Need\")\n",
        "            else:\n",
        "              swatch_response = requests.put(update_url, auth=auth, json=swatch_data)\n",
        "              if swatch_response.status_code == 200:\n",
        "                print(f\"Created Swatches Successfully\")\n",
        "              else:\n",
        "                print(\"Error in Creating Swatches\")\n",
        "\n",
        "        else:\n",
        "            print(f\"Failed to create variable parent product {parent_row['Title']}: {parent_response}\")\n",
        "\n",
        "\n",
        "# Clean up by removing the downloaded file\n",
        "if os.path.exists(\"LuxeDecor2SC_Lister.csv\"):\n",
